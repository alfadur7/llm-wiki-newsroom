{
  "_comment": "Keyword patterns for auto-classifying `## Connections` `contradicts:` claims into 4 types. Evaluated in priority order — first matching category wins. 'max_pos' (optional) requires the regex match to start before that character position in the claim (used to distinguish 'connection' language at claim start from incidental mentions later). Weights are summed per category and clamped to 1.0. Patterns are case-insensitive English (the engine compiles them with re.IGNORECASE).",
  "priority": ["related", "superseded", "real"],
  "rules": {
    "related": [
      {"pattern": "same (event|issue|matter)|same topic|similar topic", "weight": 0.8},
      {"pattern": "(shares?|aligns? (with|in)) context|same context", "weight": 0.7},
      {"pattern": "directly (connected|linked|related)", "weight": 0.7},
      {"pattern": "complement(ary|s)?|mutually reinforc", "weight": 0.7},
      {"pattern": "impact analysis", "weight": 0.5},
      {"pattern": "^related:\\s*\\[\\[", "weight": 0.8},
      {"pattern": "connect(s|ed|ion)?\\s*:?", "weight": 0.5, "max_pos": 120},
      {"pattern": "(repeats|forms|constitutes).{0,15}(pattern|structure)", "weight": 0.6},
      {"pattern": "context.{0,5}(shared|linked|connected)", "weight": 0.6},
      {"pattern": "partial(ly)? overlap|possible overlap|overlaps", "weight": 0.5},
      {"pattern": "reinforces? the (view|perspective)|adds detail", "weight": 0.5},
      {"pattern": "follow-up report|additional report", "weight": 0.4},
      {"pattern": "tie[sd]? (in|to)\\b", "weight": 0.5, "max_pos": 50},
      {"pattern": "aligns?\\s*:?", "weight": 0.6, "max_pos": 50},
      {"pattern": "(should|to) be read together|read alongside", "weight": 0.6},
      {"pattern": "directions? (align|are consistent)|consistent direction", "weight": 0.5},
      {"pattern": "related (to|:)", "weight": 0.5}
    ],
    "superseded": [
      {"pattern": "(initial|early).{0,20}(final|confirmed|tally|reported|figure)", "weight": 0.8},
      {"pattern": "(minor|refined|final)\\s*difference", "weight": 0.6},
      {"pattern": "(uncertain|tentative) (launch|release).{0,30}actual (launch|release)", "weight": 0.8},
      {"pattern": "follow-up (article|report).{0,20}(reported|actual|confirmed)", "weight": 0.7},
      {"pattern": "(expected|projected).{0,20}(final|actual).{0,20}(differs|differ|revised|gap)", "weight": 0.6},
      {"pattern": "(was )?correct(ed|ion)", "weight": 0.6},
      {"pattern": "final tally", "weight": 0.6},
      {"pattern": "situation (reversed|changed|shift)", "weight": 0.6},
      {"pattern": "swung to (profit|loss)|turned (profitable|to a loss)", "weight": 0.5},
      {"pattern": "(earlier|advance) report.{0,30}official announcement", "weight": 0.7},
      {"pattern": "(strategy|direction)\\s*(shift|change|pivot)", "weight": 0.5},
      {"pattern": "decision to (abandon|halt|withdraw)|withdrew|scrapped", "weight": 0.6},
      {"pattern": "later.{0,25}(acquisition|change|reversal|confirmed|concluded|resolved)", "weight": 0.6},
      {"pattern": "final\\s*(confirmation|decision|announcement)", "weight": 0.5},
      {"pattern": "after this point", "weight": 0.6},
      {"pattern": "(now|currently).{0,15}(already|resolved|listed|normalized)", "weight": 0.5},
      {"pattern": "needs (a status )?update|update needed", "weight": 0.5},
      {"pattern": "later.{0,20}(resulted|led|reassessed|dropped|reported|expanded|resolved|halted|shifted|reset|changed|scrapped)", "weight": 0.5},
      {"pattern": "timing difference|difference in timing", "weight": 0.7},
      {"pattern": "(scale|size) (reset|expanded|reduced|rescoped)", "weight": 0.6},
      {"pattern": "(timing|scale|schedule).{0,10}(firmed up|confirmed|changed)", "weight": 0.5}
    ],
    "real": [
      {"pattern": "(file[sd]?|filing|faces?|facing) (a |an )?(lawsuit|suit|antitrust complaint|class action)", "weight": 0.8},
      {"pattern": "\\bsue[sd]?\\b|\\bsuing\\b|\\blitigation against\\b", "weight": 0.8},
      {"pattern": "antitrust (complaint|probe|investigation|action|case)", "weight": 0.7},
      {"pattern": "(regulatory|corrective|cease.and.desist) order|injunction against", "weight": 0.7},
      {"pattern": "appeal(s|ed|ing)? (the |a )?(ruling|decision|verdict|order|fine)", "weight": 0.7},
      {"pattern": "\\bvs\\b", "weight": 0.7},
      {"pattern": "\\b(whereas|conversely|by contrast)\\b", "weight": 0.6},
      {"pattern": "the (exact )?opposite|diametrically opposed", "weight": 0.8},
      {"pattern": "opposite (result|direction)", "weight": 0.7},
      {"pattern": "\\bunlike\\b", "weight": 0.5},
      {"pattern": "conflict(s|ing|ed)?\\b", "weight": 0.8},
      {"pattern": "(clash|opposition|rebuttal|refutation|contradiction)", "weight": 0.7},
      {"pattern": "(stance|view|claim|forecast|assessment|direction|result)\\s*(difference|contrast|reversal|gap)", "weight": 0.6},
      {"pattern": "different (view|direction|perspective)", "weight": 0.5},
      {"pattern": "(claimed|announced|predicted|emphasized|analyzed|presented|forecast|noted|denied|argued),?\\s+(but|yet|however|whereas)", "weight": 0.7},
      {"pattern": "(at odds with|inconsistent with|contradict(s|ed)?)", "weight": 0.7},
      {"pattern": "in contrast (to|with)|contrasts? with", "weight": 0.5},
      {"pattern": "(but|yet)\\s+in (reality|practice|fact)", "weight": 0.5},
      {"pattern": "\\b(gap|disparity|divergence)\\b", "weight": 0.6},
      {"pattern": "tension (between|with|remains)|in tension", "weight": 0.5},
      {"pattern": "partial(ly)? (opposed|at odds|conflicting)", "weight": 0.6},
      {"pattern": "(fell|falls) short of.{0,10}(promise|expectation)|less than promised", "weight": 0.6},
      {"pattern": "(reality|in practice).{0,20}(opposite|differs|gap|harder|fell short)", "weight": 0.6},
      {"pattern": "(portrayed|depicted|framed) as.{0,10}(but|yet|however)", "weight": 0.7},
      {"pattern": "(denied|disputed).{0,5}(but|however|yet)", "weight": 0.8},
      {"pattern": "runs counter to|cuts against", "weight": 0.7},
      {"pattern": "(industry|critics|observers).{0,30}(see it differently|are skeptical|warn|criticize|question)", "weight": 0.6},
      {"pattern": "doubts? (raised|persist|grow|mount)|questions? (raised|mount)", "weight": 0.6},
      {"pattern": "concerns? (persist|grow|are raised|mount|intensify)", "weight": 0.5},
      {"pattern": "\\b(rather|instead|on the contrary)\\b", "weight": 0.3},
      {"pattern": "(similar but|seemingly alike).{0,30}(differ|gap|diverge)", "weight": 0.7},
      {"pattern": "(superficially|on the surface).{0,10}similar", "weight": 0.6},
      {"pattern": "stands? in contrast", "weight": 0.6},
      {"pattern": "in practice.{0,20}(delayed|stalled|not|opposite|lagging)", "weight": 0.6},
      {"pattern": "critic(al|ism|izes?|ized)\\b", "weight": 0.4},
      {"pattern": "(reality|situation)\\s*(gap|mismatch|contradiction)", "weight": 0.8},
      {"pattern": "(strategic )?choice (is )?(debated|contested)|(is|was) (a matter of )?debate", "weight": 0.6},
      {"pattern": "direction.{0,5}(contrasts|differs|diverges)", "weight": 0.6},
      {"pattern": "contrast(s|ed) with", "weight": 0.6},
      {"pattern": "paradoxical(ly)?", "weight": 0.7},
      {"pattern": "anomalous|unusual(ly)?", "weight": 0.5},
      {"pattern": "(remains|is)\\s*(opaque|murky|unclear)", "weight": 0.4},
      {"pattern": "skeptic(al|ism)\\b", "weight": 0.5},
      {"pattern": "reversed|reversal", "weight": 0.6},
      {"pattern": "at the same time.{0,30}(but|yet|however)", "weight": 0.6},
      {"pattern": "(approach|method|strategy)\\s*(comparison|difference|differs)", "weight": 0.5},
      {"pattern": "(differs|diverges|plays out differently)", "weight": 0.4},
      {"pattern": "(still|yet).{0,15}(skeptic|doubt|concern|distrust|unconvinced)", "weight": 0.5}
    ]
  }
